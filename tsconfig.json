{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/types/app/modulos/personal/page.tsx",
    "scripts/ejecutar-tests-sii.ts",
    "app/api/ventas/route.ts",
    ".next/dev/types/**/*.ts",
    "app/api/home/route.js",
    "app/api/ventas/masDetalles/[...id]/route.js",
    "app/api/pedidos/despacho/route.js",
    "app/api/cilindros/cargar/route.js",
    "app/api/conductor/rutaAsignada/route.js",
    "app/api/conductor/ventasEnTransito/route.js",
    "app/api/cobros/route.js",
    "app/api/ventas/historialEstados/route.js",
    "app/api/pedidos/rutasEnTransito/route.js",
    "app/api/flota/gestorCarga/route.js",
    "app/api/conductor/corregirDestino/route.js",
    "app/api/pedidos/despacho/scanItemCatalogo/route.js",
    "app/api/catalogo/subcategoria/route.js",
    "app/api/catalogo/categorias/route.js",
    "app/api/flota/byId/[...id]/route.js",
    "app/api/flota/cargaCilindros/route.js",
    "app/api/sucursales/aCargo/route.js",
    "app/api/ventas/comentar/route.js",
    "app/api/clientes/precios/route.js",
    "app/api/conductor/finalizarRuta/route.js",
    "app/api/flota/porConductor/route.js",
    "app/api/pedidos/asignacion/route.js",
    "app/api/pedidos/asignacion/sucursales/route.js",
    "app/api/auth/login/route.ts",
    "app/api/auth/register/route.js"
, "app/api/pedidos/asignacion/porAsignar/route.js", "app/api/pedidos/despacho/confirmarEntregaEnLocal/route.js", "app/api/usuarios/checklist/route.js", "app/api/cilindros/entregarEnLocal/route.js", "hooks/useOnVisibilityChange.jsx", "app/api/cilindros/gestionar/route.js"  ],
  "exclude": [
    "node_modules",
    ".next/**/*"
  ]
}
